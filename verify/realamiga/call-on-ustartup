; Lower-end baseline: stack 77000, --heap 8M.
; The 64K (65000) AmigaOS default is ~12K short for the GUI test path:
; run-tests -> (load test-gui) -> (require "amiga/gadtools") nests bi_load
; frames and then SOURCE-COMPILES gadtools.lisp (deeply-nested with-menus/
; with-gadgets macros => deep cl_compile recursion), overflowing 64K and
; silently corrupting memory ("Not a function: heap object type 0" +
; unbound *PASS-COUNT*/*FAIL-COUNT*).  Bisected threshold: 65000 FAIL,
; 77000 PASS.  See memory note amiga_gadtools_load_residual.
; Single clamiga run (sequential allocations fragment Fast RAM on the
; lower-end target).  date timestamps before/after give total runtime;
; subtract the known ~38 s boot-to-REPL on this config to estimate
; test-suite time.
cd CLAmiga:
echo "=== avail before clamiga ===" >build/amiga/test-results.log
avail >>build/amiga/test-results.log
stack 77000
echo "=== run start ===" >>build/amiga/test-results.log
date >>build/amiga/test-results.log
build/amiga/clamiga --no-userinit --heap 8M --non-interactive --load tests/amiga/run-tests.lisp >>build/amiga/test-results.log
echo "=== run end ===" >>build/amiga/test-results.log
date >>build/amiga/test-results.log
; Quit FS-UAE so `make test-amiga` returns without manual intervention.
; The host-side watchdog (run-fs-uae.sh) is the fallback if this no-ops.
C:UAEquit
